# Copy to `.env` and set the LAN-reachable IP for your gateway host.
LAN_IP=192.168.1.100

# The upstream LM Studio host/address nginx should use from inside Docker.
# On Docker Desktop this usually works as-is. On Linux, set this to the host's
# reachable LAN IP if host.docker.internal is unavailable.
LMSTUDIO_HOST=host.docker.internal

# Optional comma-separated API keys required by the gateway (send X-API-Key header)
GATEWAY_API_KEYS=

# llama.cpp server settings. Put GGUF files under ./llama-models on the host;
# inside the container they are available under /models.
LLAMA_CPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_CPP_MODELS_DIR=./llama-models
LLAMA_CPP_MODEL=/models/model.gguf
LLAMA_CPP_MODEL_ALIAS=local-gguf
LLAMA_CPP_CTX_SIZE=8192
LLAMA_CPP_PARALLEL=2
LLAMA_CPP_N_GPU_LAYERS=999
LLAMA_CPP_NVIDIA_VISIBLE_DEVICES=all

# Override defaults if needed:
AIHUB_IP=${LAN_IP}
GATEWAY_PORT=8080

# OpenRouter gateway defaults (set when enabling the OpenRouter relay)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL=minimax/minimax-m2:free
